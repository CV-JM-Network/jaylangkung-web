// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ResidentialPlan {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name              String    @db.VarChar(50)
  slug              String    @unique @db.VarChar(50)
  currentPrice      Decimal   @map("current_price") @db.Decimal(12, 2)
  originalPrice     Decimal?  @map("original_price") @db.Decimal(12, 2)
  downloadSpeedMbps Int       @map("download_speed_mbps")
  uploadSpeedMbps   Int       @map("upload_speed_mbps")
  description       String?   @db.Text
  isPopular         Boolean?  @default(false) @map("is_popular") @db.TinyInt
  displayOrder      Int?      @default(0) @map("display_order")
  isActive          Boolean?  @default(true) @map("is_active") @db.TinyInt
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)

  @@index([slug])
  @@index([isActive, displayOrder])
  @@map("residential_plans")
}
