# ==================================
# DATABASE CONFIGURATION (MariaDB)
# ==================================

# MariaDB Connection String
# Format: mysql://username:password@host:port/database_name
DATABASE_URL="mysql://brainnet_user:YOUR_PASSWORD_HERE@localhost:3306/brainnet_db"

# Database Setup Instructions:
# 1. Create database:
#    CREATE DATABASE brainnet_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# 2. Create user:
#    CREATE USER 'brainnet_user'@'localhost' IDENTIFIED BY 'strong_password_here';
#
# 3. Grant privileges:
#    GRANT ALL PRIVILEGES ON brainnet_db.* TO 'brainnet_user'@'localhost';
#    FLUSH PRIVILEGES;
#
# 4. Update DATABASE_URL above with your credentials
#
# 5. Copy this file to .env (DO NOT commit .env!):
#    cp .env.example .env

# ==================================
# OPTIONAL: API SECURITY
# ==================================

# API Key (if you want to protect the API endpoints)
# Uncomment and set if needed:
# API_KEY="your-secret-api-key-here"

# ==================================
# NEXT.JS CONFIGURATION
# ==================================

# Node environment
NODE_ENV="development"

# Application URL (for production)
# NEXT_PUBLIC_APP_URL="https://jaylangkung.co.id"
